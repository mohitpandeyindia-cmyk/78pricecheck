# 78 PriceCheck – Production Environment Variables Template

# Node runtime environment (set to 'production' for optimized runs, security blocks, and SSL redirects)
NODE_ENV=production

# Server listening port
PORT=8080

# Mandatory JWT secret key (must be a long, cryptographically secure random string in production)
JWT_SECRET=replace_this_with_a_secure_cryptographic_random_string_in_production
